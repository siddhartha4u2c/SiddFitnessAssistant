# Copy to .env locally. On Render, set these in the dashboard (Environment).

# Primary LLM via EURI (recommended)
EURI_API_KEY=
# Optional override; default in code uses EURI gateway
BASE_URL=

# Optional: Gemini API (e.g. image flows / fallback)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview
# EURI/OpenAI image size for each of the 4 weekly training panels per day (default 512x512; try 1024x1024 if the API rejects 512)
# WORKOUT_SLOT_EURI_SIZE=512x512

# --- Transactional email (activation + password reset) ---
#
# Render Free web services block outbound SMTP (ports 25, 465, 587). Use Resend over HTTPS:
RESEND_API_KEY=
# Until you verify a domain at https://resend.com/domains , Resend only sends to your Resend account email.
# Production: verify domain, then use e.g. noreply@yourdomain.com as RESEND_FROM_EMAIL.
RESEND_FROM_EMAIL=
#
# Local / paid hosts: SMTP (e.g. Gmail + App Password). Ignored for sending if RESEND_API_KEY is set.
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
MAIL_DEFAULT_SENDER=

# Public app URL for password-reset and email-activation links (no trailing slash).
# Use the exact URL users open in the browser (custom domain or …onrender.com)—not localhost in production.
PASSWORD_RESET_APP_URL=

# Render sets RENDER=true; the app warns if PASSWORD_RESET_APP_URL is still localhost in production.

# Optional: default region when saving a profile phone without +country (e.g. IN for India)
# PHONE_DEFAULT_REGION=IN
