# Copy to .env locally. On Render, set these in the dashboard (Environment).

# Primary LLM via EURI (recommended)
EURI_API_KEY=
# Optional override; default in code uses EURI gateway
BASE_URL=

# Optional: Gemini API (e.g. image flows / fallback)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview

# Optional: password-reset email
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
MAIL_DEFAULT_SENDER=

# After deploy, set to your public URL (e.g. https://sidd-fitness-assistant.onrender.com)
PASSWORD_RESET_APP_URL=

# Optional: Sign in with Google (OAuth web client). Redirect URI must match Google Cloud Console exactly.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=https://your-app.onrender.com/

# Optional: SMS OTP (Twilio). https://www.twilio.com/docs/sms
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=+1234567890
# Or same as Twilio "From" number (e.g. on Render):
# TWILIO_PHONE_NUMBER=+1234567890
# Or use a Messaging Service SID instead of a From number:
# TWILIO_MESSAGING_SERVICE_SID=
# Default region when parsing numbers without +country (e.g. IN for India)
# PHONE_DEFAULT_REGION=IN
