# Copy to .env locally. On Render, set these in the dashboard (Environment).

# Primary LLM via EURI (recommended)
EURI_API_KEY=
# Optional override; default in code uses EURI gateway
BASE_URL=

# Optional: Gemini API (e.g. image flows / fallback)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview

# Optional: password-reset email
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
MAIL_DEFAULT_SENDER=

# After deploy, set to your public URL (e.g. https://sidd-fitness-assistant.onrender.com)
PASSWORD_RESET_APP_URL=

# Optional: Sign in with Google (OAuth web client). Authorized redirect URI in Google Cloud must match.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=https://your-app.onrender.com/
# If GOOGLE_OAUTH_REDIRECT_URI is empty, the app uses PASSWORD_RESET_APP_URL or APP_BASE_URL with a trailing /
# APP_BASE_URL=https://your-app.onrender.com

# Optional: default region when saving a profile phone without +country (e.g. IN for India)
# PHONE_DEFAULT_REGION=IN
